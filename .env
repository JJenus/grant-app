# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://root_user:pass123@localhost:5432/grantportal_db"

# JWT secret for admin sessions — make this long and random
JWT_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# ─── Site Identity (used for SEO, emails, and OG link previews) ───────────────

# Your public domain — NO trailing slash
# Change this once when you deploy; all canonical URLs and OG tags update automatically
APP_URL="https://grantportalngn.vercel.app"

# Shown in browser tab titles and OG site_name
SITE_NAME="GrantPortal"

# Default meta description for link previews when no page-specific one is set
SITE_DESCRIPTION="Funding ideas that matter. Apply for grants supporting community development, education, environment, health, arts, and economic opportunity."

# ─── Optional ────────────────────────────────────────────────────────────────

# Default admin password created on first boot (default: admin123)
ADMIN_PASSWORD="admin123"

# SMTP — if not set, emails are printed to console instead of sent
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="grants@yourdomain.com"
